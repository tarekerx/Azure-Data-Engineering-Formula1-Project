        {
          "task_key": "02_Create_New_Batch"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "run_job_task": {
        "job_id": 224389159292478,
        "job_parameters": {
          "p_batch_id": "{{tasks.01_Identify_Next_Batch.values.p_batch_id}}"
        }
      },
