resources:
  jobs:
    Formula1_incremental_Full_Refresh:
      name: Formula1-incremental Full Refresh
      email_notifications:
        on_start:
          - tarekihape@gmail.com
        on_success:
          - tarekihape@gmail.com
        on_failure:
          - tarekihape@gmail.com
        on_duration_warning_threshold_exceeded:
          - tarekihape@gmail.com
      timeout_seconds: 600
      health:
        rules:
          - metric: RUN_DURATION_SECONDS
            op: GREATER_THAN
            value: 420
      trigger:
        pause_status: UNPAUSED
        table_update:
          table_names:
            - formula1.control.batch_events
      tasks:
        - task_key: 00_Build_Nationality_Region_Reference
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/04-gold/91.Build
              Nationality Region Refrence
            source: WORKSPACE
        - task_key: 01_Ingest_Circuits
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/02-bronze/01.Ingest
              Circuits File
            source: WORKSPACE
        - task_key: 01_Ingest_Constructors
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/02-bronze/03.Ingest
              Constructors File
            source: WORKSPACE
        - task_key: 01_Ingest_Drivers
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/02-bronze/04.Ingest
              drivers.json file
            source: WORKSPACE
        - task_key: 01_Ingest_Races
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/02-bronze/02.Ingest
              Races File
            source: WORKSPACE
        - task_key: 01_Ingest_Results
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/02-bronze/05.Ingest
              results files
            source: WORKSPACE
        - task_key: 01_Ingest_Sprints
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/02-bronze/06.Ingest
              sprints files
            source: WORKSPACE
        - task_key: 02_Transform_Circuits
          depends_on:
            - task_key: 01_Ingest_Circuits
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/03-silver/01.Circuits
              transformation
            source: WORKSPACE
        - task_key: 02_Transform_Constructors
          depends_on:
            - task_key: 01_Ingest_Constructors
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/03-silver/03.Constructors
              transformation
            source: WORKSPACE
        - task_key: 02_Build_Constructors_Dim
          depends_on:
            - task_key: 02_Transform_Constructors
            - task_key: 00_Build_Nationality_Region_Reference
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/04-gold/02.Build
              Constructors Dimension
            source: WORKSPACE
        - task_key: 02_Transform_Drivers
          depends_on:
            - task_key: 01_Ingest_Drivers
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/03-silver/06.Drivers
              transformation
            source: WORKSPACE
        - task_key: 02_Transform_Races
          depends_on:
            - task_key: 01_Ingest_Races
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/03-silver/02.Races
              transformation
            source: WORKSPACE
        - task_key: 02_Transform_Results
          depends_on:
            - task_key: 01_Ingest_Results
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/03-silver/05.Results
              transformation
            source: WORKSPACE
        - task_key: 02_Transform_Sprints
          depends_on:
            - task_key: 01_Ingest_Sprints
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/03-silver/04.Sprints
              transformation
            source: WORKSPACE
        - task_key: 03_Build_Drivers_Dim
          depends_on:
            - task_key: 00_Build_Nationality_Region_Reference
            - task_key: 02_Transform_Drivers
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/04-gold/03.Build
              Drivers Dimension
            source: WORKSPACE
        - task_key: 03_Build_Races_Dim
          depends_on:
            - task_key: 02_Transform_Races
            - task_key: 02_Transform_Circuits
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/04-gold/01.Build Races
              Dimension
            source: WORKSPACE
          environment_key: Env_Build_Races_Dim
        - task_key: 03_Build_Session_Results_Fact
          depends_on:
            - task_key: 02_Transform_Results
            - task_key: 02_Transform_Sprints
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/04-gold/04.Build
              Session Results Fact
            source: WORKSPACE
      queue:
        enabled: true
      parameters:
        - name: p_batch_id
          default: ""
      environments:
        - environment_key: Env_Build_Races_Dim
          spec:
            environment_version: "5"
      performance_target: PERFORMANCE_OPTIMIZED
