resources:
  jobs:
    job_formula1_incremental_batch_orchestration:
      name: job_formula1_incremental_batch_orchestration
      tasks:
        - task_key: 01_Identify_Next_Batch
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/06-orchestration/01.Identify
              Next Batch
            source: WORKSPACE
        - task_key: Is_There_A_Batch_To_Process
          depends_on:
            - task_key: 01_Identify_Next_Batch
          condition_task:
            op: EQUAL_TO
            left: "{{tasks.01_Identify_Next_Batch.values.has_batch}}"
            right: "true"
        - task_key: 02_Create_New_Batch
          depends_on:
            - task_key: Is_There_A_Batch_To_Process
              outcome: "true"
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/06-orchestration/02.Create
              New Batch
            base_parameters:
              p_batch_id: "{{tasks.01_Identify_Next_Batch.values.p_batch_id}}"
            source: WORKSPACE
        - task_key: run_jon_Formula1-incremental_Full_Refresh
          depends_on:
            - task_key: 02_Create_New_Batch
          run_job_task:
            job_id: 224389159292478
            job_parameters:
              p_batch_id: "{{tasks.01_Identify_Next_Batch.values.p_batch_id}}"
        - task_key: 03_Complete_Batch
          depends_on:
            - task_key: run_jon_Formula1-incremental_Full_Refresh
          notebook_task:
            notebook_path: /Workspace/Users/tarekihape@gmail.com/databricks
              course/formula1-projects-increamental-load/06-orchestration/03.Complete
              Batch
            base_parameters:
              p_batch_id: "{{tasks.01_Identify_Next_Batch.values.p_batch_id}}"
            source: WORKSPACE
      queue:
        enabled: true
      performance_target: PERFORMANCE_OPTIMIZED
