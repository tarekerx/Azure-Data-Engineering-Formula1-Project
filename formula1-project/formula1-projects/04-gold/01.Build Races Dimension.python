nuid":"e449780a-c4d7-421c-80ef-a5f68949f6a1"},{"version":"CommandV1","origId":7216504859342030,"guid":"650d3982-9070-4825-8a2f-476b0c8d8d57","subtype":"command","commandType":"auto","position":600.0,"command":"races_df = spark.table(races_silver_table_source)\ncircuits_df = spark.table(circuits_silver_table_source)","commandVersion":0,"state":"finished","results":{"type":"listResults","data":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"races_df","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"circuit_id","nullable":true,"type":"string"},{"metadata":{},"name":"season","nullable":true,"type":"integer"},{"metadata":{},"name":"round","nullable":true,"type":"integer"},{"metadata":{},"name":"race_name","nullable":true,"type":"string"},{"metadata":{},"name":"race_date","nullable":true,"type":"date"}],"type":"struct"},"tableIdentifier":null},{"name":"circuits_df","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"circuit_id","nullable":true,"type":"string"},{"metadata":{},"name":"circuit_name","nullable":true,"type":"string"},{"metadata":{},"name":"latitude","nullable":true,"type":"double"},{"metadata":{},"name":"longitude","nullable":true,"type":"double"},{"metadata":{},"name":"locality","nullable":true,"type":"string"},{"metadata":{},"name":"country","nullable":true,"type":"string"}],"type":"struct"},"tableIdentifier":null}],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1782233831306,"submitTime":1782233828023,"finishTime":1782233832380,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"eea206e0-f51a-42de-84ec-13f59a92f563"},{"version":"CommandV1","origId":7216504859342025,"guid":"7cd2114c-04ec-4a59-8887-c642b90354c8","subtype":"command","commandType":"auto","position":100.0,"command":"%md\n# Dimension Building: `dim_races`\nThis notebook extracts race and circuit data from the **Silver layer**, joins them, and loads the transformed dimension data into the **Gold layer**.\n\n---\n\n### 1. Data Ingestion (Silver Layer)\n* **Read** the `silver.races` table.\n* **Read** the `silver.circuits` table.\n\n### 2. Transformation Logic\n* **Join** both tables on the common key: `circuit_id`.\n* **Select & Rename** the following target columns:\n\n| Source Table | Source Column | Notes |\n| :--- | :--- | :--- |\n| `races` | `season` | |\n| `races` | `round` | |\n| `races` | `race_name` | |\n| `races` | `race_date` | |\n| `circuits` | `circuit_name` | |\n| `circuits` | `locality` | City/Local area |\n| `circuits` | `country` | |\n\n### 3. Data Loading (Gold Layer)\n* **Write** the final transformed DataFrame into the `gold.dim_race` table.","commandVersion":0,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"e8aad15b-a237-44a1-8efc-1c72e22dfa70"},{"version":"CommandV1","origId":7216504859342026,"guid":"2d688197-3e91-4086-ae34-b4cad703fb14","subtype":"command","commandType":"auto","position":200.0,"command":"%md\n![{B936279C-5978-442F-85D2-C7644D229C5C}.png](./{B936279C-5978-442F-85D2-C7644D229C5C}.png \"{B936279C-5978-442F-85D2-C7644D229C5C}.png\")","commandVersion":0,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex