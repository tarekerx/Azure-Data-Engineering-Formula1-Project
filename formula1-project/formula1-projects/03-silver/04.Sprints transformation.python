,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"6068fcf5-092f-4ec2-a277-88eb80795fa9"},{"version":"CommandV1","origId":7216504859341985,"guid":"1ff3fa9d-ccb0-4b2a-9b28-6ff5763022dd","subtype":"command","commandType":"auto","position":200.0,"command":"\n\n\n\n\nfile_name = 'sprints'\nbronze_table = f'{catalog}.{bronze_schema}.{file_name}'\nsilver_table = f'{catalog}.{silver_schema}.{file_name}'\n\n\n\nsprints_df = spark.read.table(bronze_table)\ndisplay(sprints_df)\n\nfrom pyspark.sql import functions as F\n\nsprints_select_df = sprints_df.drop(F.col('url'))\ndisplay(sprints_select_df)\n\nsprints_final_df = (\n    sprints_select_df\n        .withColumnsRenamed({\n            \"constructorId\": \"constructor_id\",\n            \"driverId\": \"driver_id\",\n            \"raceName\": \"race_name\",\n            \"date\": \"race_date\",\n            \"grid\": \"grid_position\",\n            \"laps\": \"completed_laps\",\n            \"number\": \"car_number\",\n            \"position\": \"final_position\",\n            \"positionText\": \"final_position_text\"\n        }).filter(F.col(\"season\").isNotNull() & F.col(\"round\").isNotNull() & F.col(\"constructor_id\").isNotNull()).dropDuplicates([\"season\",'round',\"constructor_id\",\"driver_id\"]).withColumn('race_name',F.initcap(F.col('race_name')))\n)\ndisplay(sprints_final_df)\n\n# Pass the variable name into the SQL string using an f-string\nspark.sql(f\"DROP TABLE IF EXISTS {silver_table}\")\n\n# Now write the dataframe (it will create a fresh table with the new schema)\nsprints_final_df.write.format('delta').mode('overwrite').saveAsTable(silver_table)\n\n# COMMAND ----------\n\ndisplay(spark.sql(f\"select * from {silver_table}\"))","commandVersion":13,"state":"error","results":{"type":"listResults","data":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":"NameError: name 'catalog' is not defined","errorTraceType":"baseError","error":"\u001B[0;31m---------------------------------------------------------------------------\u001B[0m\n\u001B[0;31mNameError\u001B[0m                                 Traceback (most recent call last)\nFile \u001B[0;32m<command-7216504859341985>, line 7\u001B[0m\n\u001B[1;32m      6\u001B[0m file_name \u001B[38;5;241m=\u001B[39m \u001B[38;5;124m'\u001B[39m\u001B[38;5;124msprints\u001B[39m\u001B[38;5;124m'\u001B[39m\n\u001B[0;32m----> 7\u001B[0m bronze_table \u001B[38;5;241m=\u001B[39m \u001B[38;5;124mf\u001B[39m\u001B[38;5;124m'\u001B[39m\u001B[38;5;132;01m{\u001B[39;00m\u001B[43mcatalog\u001B[49m\u001B[38;5;132;01m}\u001B[39;00m\u001B[38;5;124m.\u001B[39m\u001B[38;5;132;01m{\u001B[39;00mbronze_schema\u001B[38;5;132;01m}\u001B[39;00m\u001B[38;5;124m.\u001B[39m\u001B[38;5;132;01m{\u001B[39;00mfile_name\u001B[38;5;132;01m}\u001B[39;00m\u001B[38;5;124m'\u001B[39m\n\u001B[1;32m      8\u001B[0m silver_table \u001B[38;5;241m=\u001B[39m \u001B[38;5;124mf\u001B[39m\u001B[38;5;124m'\u001B[39m\u001B[38;5;132;01m{\u001B[39;00mcatalog\u001B[38;5;132;01m}\u001B[39;00m\u001B[38;5;124m.\u001B[39m\u001B[38;5;132;01m{\u001B[39;00msilver_schema\u001B[38;5;132;01m}\u001B[39;00m\u001B[38;5;124m.\u001B[39m\u001B[38;5;132;01m{\u001B[39;00mfile_name\u001B[38;5;132;01m}\u001B[39;00m\u001B[38;5;124m'\u001B[39m\n\u001B[1;32m     12\u001B[0m sprints_df \u001B[38;5;241m=\u001B[39m spark\u001B[38;5;241m.\u001B[39mread\u001B[38;5;241m.\u001B[39mtable(bronze_table)\n\n\u001B[0;31mNameError\u001B[0m: name 'catalog' is not defined","errorDetails":null,"baseErrorDetails":{"type":"baseErro